# 服务器端口（Railway 会自动设置）
PORT=9091

# Supabase 数据库配置（必需）
COZE_SUPABASE_URL=你的Supabase项目URL
COZE_SUPABASE_ANON_KEY=你的Supabase匿名密钥

# 火山引擎 AI 配置（必需 - 用于 AI 营养助手功能）
# 获取方式：
# 1. 登录火山引擎控制台：https://console.volcengine.com/ark
# 2. 创建接入点（模型推理 -> 接入点管理 -> 创建接入点）
# 3. 选择模型：聊天用 doubao-1.5-pro，视觉用 doubao-seed-1.6-vision
# 4. 复制接入点 ID（格式如 ep-20260404113823-wx898）
VOLCENGINE_API_KEY=你的火山引擎API密钥
VOLCENGINE_API_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_CHAT_MODEL=ep-你的聊天模型接入点ID
VOLCENGINE_VISION_MODEL=ep-你的视觉模型接入点ID
